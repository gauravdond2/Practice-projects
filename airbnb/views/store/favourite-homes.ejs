<%- include('../partials/head') %>
</head>
<body>
   <%- include('../partials/header') %>
   <h1>Here are our Favourites Homes</h1>
      <div class="container mx-auto p-4">
    <h1 class="text-3xl font-bold mb-6">Here are our favourite Homes</h1>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% homes.forEach(home => { %>
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <img src="<%= home.photo %>" alt="Home photo" class="w-full h-48 object-cover">
                <div class="p-4">
                    <h2 class="text-xl font-semibold mb-2"><%= home.homeName %></h2>
                    <p class="text-gray-600 mb-1"><%= home.location %></p>
                    <p class="text-yellow-500 mb-2">Rating: <%= home.rating %></p>
                    <p class="text-lg font-bold text-green-600">$<%= home.pricePerNight %> / night</p>
                </div>
            <a href="/homes/<%= home.id %>" class=" bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow transition-colors duration-200">Details</a>
            <div class="flex justify-between items-center mt-2">
                <div class="ml-auto">
                    <a href="/romovehome/<%= home.id %>" class=" inline-block bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded shadow transition-colors duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </a>
                </div>
            </div>
            </div>
        <% }) %>
    </div>
   </div>

       <script src="https://cdn.tailwindcss.com"></script>
</body>

</html>